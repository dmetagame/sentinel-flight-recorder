{
  "name": "sentinel-flight-recorder",
  "version": "0.1.0",
  "description": "MCP-native safety benchmark and execution-control plane for autonomous Bitget trading agents.",
  "type": "module",
  "private": true,
  "scripts": {
    "anchor": "node scripts/anchor-merkle.mjs",
    "bench": "node src/bench/run.js",
    "demo": "node src/demo.js",
    "dev": "node src/server.js",
    "deploy:vercel": "npx vercel@latest --prod --yes",
    "icons": "node scripts/generate-icons.mjs && node scripts/generate-og.mjs",
    "mcp:proxy": "node src/mcp-proxy.js",
    "test": "node --test"
  },
  "devDependencies": {
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5",
    "viem": "^2.53.1"
  },
  "overrides": {
    "ws": "8.21.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "bitget",
    "mcp",
    "trading-agent",
    "risk-engine",
    "hackathon"
  ],
  "license": "MIT"
}
